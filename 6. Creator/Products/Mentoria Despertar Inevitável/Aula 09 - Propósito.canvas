		{"id":"a0a8fbc34eb2dd20","x":-180,"y":-41,"width":154,"height":60,"color":"6","type":"text","text":"**Propósito**"},
		{"id":"ba30ba88ecf9c1a8","x":143,"y":-101,"width":168,"height":60,"type":"text","text":"**Eckhart Tolle**"},
		{"id":"2ba54fd9bc3c31a1","x":143,"y":99,"width":150,"height":60,"type":"text","text":"**Bashar**"},
