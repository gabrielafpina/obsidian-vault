402514,0.00940216,0.07645314,-0.04583958,-0.04116738,-0.00564538,0.16673703,-0.03053352,-0.0604708,0.01539869,-0.01152077,0.02815299,0.01061596,0.00504753,-0.01088028,0.00400365,0.12088843,-0.0002623,0.01429404,0.03247698,-0.03427259,0.0644101,0.08029119,-0.02259478,-0.06794378,0.0100997,-0.05962592,0.05411922,0.09058362,-0.0351414,0.00192331,-0.0335889,-0.0032178,0.01017275,-0.02245143,-0.02871043,-0.03300186,0.05190352,0.03690703,0.00337103,-0.02660233,0.00193778,-0.00370056,0.00890408,-0.00471777,0.05058612,0.00703969,0.0518129,0.02683753],"last_embed":{"tokens":469,"hash":"1wgjwww"}}},"text":null,"length":0,"last_read":{"hash":"1wgjwww","at":1777601485786},"key":"2. Literature Notes/Topics/O que é a resistência?.md######**FRASES:**","lines":[39,65],"size":1257,"outlinks":[{"title":"Cada parte está tentando nos proteger ou beneficiar de alguma forma","target":"Cada parte está tentando nos proteger ou beneficiar de alguma forma","line":10},{"title":"Como a Ansiedade e Procrastinação te atrasam?","target":"Como a Ansiedade e Procrastinação te atrasam?","line":11},{"title":"Tão inexorável quanto alimentar o corpo para que não morra, é alimentar a alma, fazendo aquilo que ela veio ao mundo para fazer.","target":"Tão inexorável quanto alimentar o corpo para que não morra, é alimentar a alma, fazendo aquilo que ela veio ao mundo para fazer.","line":14},{"title":"O ser humano tem duas vidas","target":"O ser humano tem duas vidas","line":15},{"title":"Quais são os medos que mais seguram as pessoas?","target":"Quais são os medos que mais seguram as pessoas?","line":16},{"title":"Você pode dominar, mas ninguém supera o medo","target":"Você pode dominar, mas ninguém supera o medo","line":17},{"title":"Existe um acordo tácito por permanecer na mediocridade","target":"Existe um acordo tácito por permanecer na mediocridade","line":18},{"title":"O melhor que você pode fazer pelas pessoas é avançar e dá exemplo","target":"O melhor que você pode fazer pelas pessoas é avançar e dá exemplo","line":19},{"title":"O artista não tolera confusões em sua vida, pois isso o impede de fazer o seu trabalho","target":"O artista não tolera confusões em sua vida, pois isso o impede de fazer o seu trabalho","line":20},{"title":"Só vamos fazer as coisas, se fizermos APESAR do que acontecer","target":"Só vamos fazer as coisas, se fizermos APESAR do que acontecer","line":21},{"title":"O ser humano tem duas vidas","target":"O ser humano tem duas vidas","line":22},{"title":"O universo é um grande quebra cabeça onde cada um de nós traz uma peça","target":"O universo é um grande quebra cabeça onde cada um de nós traz uma peça","line":23},{"title":"Vitimização é o palco onde a resistência veste o drama, prendendo todos em um enredo de medos imaginários","target":"Vitimização é o palco onde a resistência veste o drama, prendendo todos em um enredo de medos imaginários","line":24},{"title":"O que é o bom karma?","target":"O que é o bom karma?","line":25},{"title":"Uma pessoa que luta para realizar seus sonhos não tem tempo nem interesse em criticar ninguém","target":"Uma pessoa que luta para realizar seus sonhos não tem tempo nem interesse em criticar ninguém","line":26},{"title":"A essência é a alquimia da alma, transformando adversidades em ouro puro de experiência","target":"A essência é a alquimia da alma, transformando adversidades em ouro puro de experiência","line":27}],"class_name":"SmartBlock"},
